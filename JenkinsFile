pipeline{
    options{
        timeout(time: 5, "MINUTES")
        timestamp()
    }
    stages{
        stage("make a directory"){
            steps{
                sh "mkdir jenkins-test"
            }
        }
        stage("add a file"){
            steps{
                sh "touch jenkins-test/BigNew.txt"
            }
        }
    }
    post {
        always {
            archiveArtifacts artifcats: "jenkins-test/BigNew.txt", allowEmptyArchive true
        }
    }
}